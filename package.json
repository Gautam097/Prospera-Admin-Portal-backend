{
    "name": "nodejs-backend-api",
    "version": "1.0.0",
    "description": "Scalable Node.js Backend API with PostgreSQL and Prisma",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "cross-env TZ=UTC node server.js",
        "dev": "cross-env TZ=UTC nodemon server.js",
        "format": "prettier --write .",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:seed": "prisma db seed",
        "db:studio": "prisma studio",
        "db:reset": "prisma migrate reset",
        "swagger:generate": "node scripts/swagger/generate-swagger.js",
        "build": "node scripts/build.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.844.0",
        "@aws-sdk/client-ses": "^3.844.0",
        "@aws-sdk/s3-request-presigner": "^3.844.0",
        "@prisma/client": "^6.11.1",
        "app-root-path": "^3.1.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-session": "^1.18.1",
        "express-validator": "^7.0.1",
        "file-stream-rotator": "^1.0.0",
        "fireblocks-sdk": "^5.38.0",
        "geoip-lite": "^1.4.10",
        "helmet": "^7.1.0",
        "ioredis": "^5.6.1",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^4.2.1",
        "node-fetch": "^3.3.2",
        "nodemailer": "^6.9.7",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "phone": "^3.1.62",
        "qrcode": "^1.5.4",
        "redis": "^4.6.10",
        "speakeasy": "^2.0.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "twilio": "^5.7.3",
        "ua-parser-js": "^2.0.4",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "cross-env": "^10.0.0",
        "eslint": "^8.55.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "install": "^0.13.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.10",
        "prettier": "^3.6.2",
        "prisma": "^6.11.1",
        "supertest": "^6.3.3"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "jest": {
        "preset": "jest-esm-transformer"
    },
    "keywords": [
        "nodejs",
        "express",
        "postgresql",
        "prisma",
        "rest-api"
    ],
    "author": "",
    "license": "MIT"
}
